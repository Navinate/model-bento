---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'AI model cards as Apple-style bento presentations' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.bunny.net" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.bunny.net/css?family=fraunces:400,500,600,700,800,900|geist:400,500,600,700|geist-mono:400,500&display=swap"
    />
    <slot name="head" />
  </head>
  <body class="min-h-screen antialiased">
    <slot />
  </body>
</html>
