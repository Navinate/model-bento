---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/global.css';
import { db } from '../../lib/db';
import { models, bentoPages, users } from '../../lib/schema';
import { eq, sql, isNotNull, count } from 'drizzle-orm';

const [modelCount] = await db.select({ count: count() }).from(models);
const [userCount] = await db.select({ count: count() }).from(users);
const [bannedCount] = await db.select({ count: count() }).from(users).where(isNotNull(users.bannedAt));

const allModels = await db
  .select({
    provider: models.provider,
    name: models.name,
    displayName: models.displayName,
    createdAt: models.createdAt,
  })
  .from(models)
  .orderBy(models.createdAt);
---

<BaseLayout title="Admin — Model Bento">
  <main class="mx-auto max-w-5xl p-8">
    <h1 class="text-3xl font-bold text-slate-900 mb-8">Admin Dashboard</h1>

    <div class="grid grid-cols-3 gap-4 mb-8">
      <div class="rounded-xl bg-white border border-slate-200 p-6 text-center">
        <p class="text-3xl font-bold text-slate-900">{modelCount.count}</p>
        <p class="text-sm text-slate-500">Models</p>
      </div>
      <div class="rounded-xl bg-white border border-slate-200 p-6 text-center">
        <p class="text-3xl font-bold text-slate-900">{userCount.count}</p>
        <p class="text-sm text-slate-500">Users</p>
      </div>
      <div class="rounded-xl bg-white border border-slate-200 p-6 text-center">
        <p class="text-3xl font-bold text-slate-900">{bannedCount.count}</p>
        <p class="text-sm text-slate-500">Banned</p>
      </div>
    </div>

    <div class="flex gap-4 mb-6">
      <a href="/admin" class="text-sm font-medium text-slate-900 border-b-2 border-slate-900 pb-1">Models</a>
      <a href="/admin/users" class="text-sm font-medium text-slate-500 hover:text-slate-900 pb-1">Users</a>
    </div>

    <div class="overflow-x-auto">
      <table class="w-full text-left">
        <thead>
          <tr class="border-b border-slate-200">
            <th class="py-3 text-sm font-medium text-slate-500">Provider</th>
            <th class="py-3 text-sm font-medium text-slate-500">Model</th>
            <th class="py-3 text-sm font-medium text-slate-500">Display Name</th>
            <th class="py-3 text-sm font-medium text-slate-500">Actions</th>
          </tr>
        </thead>
        <tbody>
          {allModels.map((m) => (
            <tr class="border-b border-slate-100">
              <td class="py-3 text-sm">{m.provider}</td>
              <td class="py-3 text-sm">{m.name}</td>
              <td class="py-3 text-sm font-medium">{m.displayName}</td>
              <td class="py-3 text-sm">
                <a href={`/admin/m/${m.provider}/${m.name}`} class="text-blue-600 hover:underline">
                  Manage
                </a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </main>
</BaseLayout>
