---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import '../../../styles/global.css';
import { db } from '../../../lib/db';
import { users, models } from '../../../lib/schema';
import { eq, count, isNotNull } from 'drizzle-orm';

const allUsers = await db
  .select({
    id: users.id,
    username: users.username,
    githubId: users.githubId,
    avatarUrl: users.avatarUrl,
    bannedAt: users.bannedAt,
    createdAt: users.createdAt,
  })
  .from(users)
  .orderBy(users.createdAt);
---

<BaseLayout title="Admin Users — Model Bento">
  <main class="mx-auto max-w-5xl p-8">
    <h1 class="text-3xl font-bold text-slate-900 mb-8">Admin Dashboard</h1>

    <div class="flex gap-4 mb-6">
      <a href="/admin" class="text-sm font-medium text-slate-500 hover:text-slate-900 pb-1">Models</a>
      <a href="/admin/users" class="text-sm font-medium text-slate-900 border-b-2 border-slate-900 pb-1">Users</a>
    </div>

    <div class="overflow-x-auto">
      <table class="w-full text-left">
        <thead>
          <tr class="border-b border-slate-200">
            <th class="py-3 text-sm font-medium text-slate-500">User</th>
            <th class="py-3 text-sm font-medium text-slate-500">GitHub ID</th>
            <th class="py-3 text-sm font-medium text-slate-500">Status</th>
            <th class="py-3 text-sm font-medium text-slate-500">Actions</th>
          </tr>
        </thead>
        <tbody>
          {allUsers.map((u) => (
            <tr class="border-b border-slate-100">
              <td class="py-3 text-sm flex items-center gap-2">
                {u.avatarUrl && <img src={u.avatarUrl} alt="" class="w-6 h-6 rounded-full" />}
                {u.username}
              </td>
              <td class="py-3 text-sm text-slate-500">{u.githubId}</td>
              <td class="py-3 text-sm">
                {u.bannedAt ? (
                  <span class="rounded-full bg-red-100 px-2 py-0.5 text-xs text-red-700">Banned</span>
                ) : (
                  <span class="rounded-full bg-green-100 px-2 py-0.5 text-xs text-green-700">Active</span>
                )}
              </td>
              <td class="py-3 text-sm">
                <a href={`/admin/users/${u.id}`} class="text-blue-600 hover:underline">Manage</a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </main>
</BaseLayout>
